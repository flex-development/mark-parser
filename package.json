{
  "name": "@flex-development/mark-parser",
  "description": "finite state machine tokenizer",
  "version": "1.0.0-alpha.9",
  "keywords": [
    "fsm",
    "lexer",
    "parse",
    "state",
    "tokenize"
  ],
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/flex-development/mark-parser",
  "repository": "https://github.com/flex-development/mark-parser.git",
  "bugs": "https://github.com/flex-development/mark-parser/issues",
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/flex-development"
    }
  ],
  "author": {
    "name": "Lexus Drumgold",
    "url": "https://github.com/unicornware"
  },
  "publishConfig": {
    "access": "public",
    "diff-dst-prefix": "mark-parser",
    "diff-src-prefix": "mark-parser",
    "directory": "./",
    "executableFiles": [],
    "node-options": null,
    "pack-destination": ".",
    "parseable": true,
    "prefer-dedupe": true,
    "provenance": true,
    "tag-version-prefix": ""
  },
  "type": "module",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "mark-parser": "./src/index.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json",
    "./utils": {
      "mark-parser": "./src/utils/index.mts",
      "default": "./dist/utils/index.mjs"
    }
  },
  "imports": {
    "#constructs/*": {
      "mark-parser": "./src/constructs/*.mts",
      "default": "./dist/constructs/*.mjs"
    },
    "#create-tokenizer": {
      "mark-parser": "./src/create-tokenizer.mts",
      "default": "./dist/create-tokenizer.mjs"
    },
    "#fixtures/*": "./__fixtures__/*.mts",
    "#interfaces/*": {
      "mark-parser": "./src/interfaces/*.mts",
      "default": "./dist/interfaces/*.d.mts"
    },
    "#internal/*": {
      "mark-parser": "./src/internal/*.mts",
      "default": "./dist/internal/*.mjs"
    },
    "#preprocess": {
      "mark-parser": "./src/preprocess.mts",
      "default": "./dist/preprocess.mjs"
    },
    "#tests/*": "./__tests__/*.mts",
    "#tokenize": {
      "mark-parser": "./src/tokenize.mts",
      "default": "./dist/tokenize.mjs"
    },
    "#types/*": {
      "mark-parser": "./src/types/*.mts",
      "default": "./dist/types/*.d.mts"
    },
    "#utils/*": {
      "mark-parser": "./src/utils/*.mts",
      "default": "./dist/utils/*.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "remarkConfig": {
    "plugins": [
      "@flex-development/remark-preset"
    ]
  },
  "scripts": {
    "build": "yarn clean:build && tsc -p tsconfig.build.json --noEmit false && rollup -c=rollup.config.mts && trash dist/{constructs,interfaces,internal,types,utils}/** dist/*.{d.mts,mjs} \"!dist/index.{d.mts,mjs}\" \"!dist/utils/index.{d.mts,mjs}\" && delete-empty dist",
    "check:ci": "yarn dedupe --check && yarn check:format && yarn check:lint && yarn check:spelling && yarn typecheck && yarn check:types && yarn test:cov && attw --pack && yarn check:types:build",
    "check:format": "dprint check --incremental=false",
    "check:lint": "eslint --exit-on-fatal-error --max-warnings 0 .",
    "check:spelling": "cspell lint --color --no-progress --relative $@ \"**\"",
    "check:types": "tsc -p tsconfig.typecheck.json",
    "check:types:build": "tsc -p tsconfig.build.json",
    "check:upgrades": "yarn upgrade-interactive",
    "clean:build": "trash \"./{dist,*.tgz}\" || exit 0",
    "clean:modules": "trash ./.yarn/{cache,*.gz} ./node_modules",
    "clean:pack": "trash \"./*.tgz\"",
    "clean:test": "trash ./coverage && trash __tests__/reports",
    "codecov": "yarn test:cov && yarn test:cov:upload",
    "codecov:validate": "cat .codecov.yml | curl --data-binary @- https://codecov.io/validate",
    "commitlint": "commitlint -V",
    "fix:cg": "yarn fix:format && yarn fix:lint",
    "fix:dedupe": "yarn dedupe --strategy=highest",
    "fix:format": "dprint fmt",
    "fix:lint": "yarn check:lint --cache --fix",
    "postinstall": "[ -f ./.git ] && [ -f ./node_modules/.bin/husky ] && chmod +x .husky/_/* && husky || exit 0",
    "postpack": "toggle-scripts +postinstall",
    "postpublish": "toggle-scripts +prepack",
    "prepack": "toggle-scripts -postinstall && yarn build",
    "prepublishOnly": "toggle-scripts -prepack",
    "release": "bash ./scripts/release.sh",
    "remark": "remark .",
    "test": "yarn clean:build; vitest run",
    "test:cov": "yarn test --coverage",
    "test:cov:reports": "yarn test:cov --merge-reports --mode=reports",
    "test:cov:ui": "yarn test:ui --coverage",
    "test:cov:upload": "./codecov -t $CODECOV_TOKEN -f ./coverage/lcov.info",
    "test:reports": "yarn test --merge-reports --mode=reports",
    "test:ui": "cross-env VITEST_UI=1 vitest --ui",
    "typecheck": "yarn test --typecheck --mode=typecheck",
    "typecheck:ui": "yarn test:ui --typecheck --mode=typecheck"
  },
  "dependencies": {
    "@flex-development/mark": "1.0.0-alpha.1",
    "@flex-development/mark-util-character": "1.0.0",
    "@flex-development/mark-util-chunked": "1.0.0",
    "@flex-development/mark-util-symbol": "3.1.0",
    "@flex-development/unist-util-builder": "2.0.0",
    "debug": "4.4.3",
    "devlop": "1.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@codecov/rollup-plugin": "2.0.1",
    "@commitlint/cli": "21.2.0",
    "@commitlint/types": "21.2.0",
    "@edge-runtime/vm": "5.0.0",
    "@flex-development/commitlint-config": "1.0.1",
    "@flex-development/eslint-config": "1.1.1",
    "@flex-development/export-regex": "2.0.0",
    "@flex-development/grease": "3.0.0-alpha.9",
    "@flex-development/import-regex": "3.0.0",
    "@flex-development/pathe": "4.0.2",
    "@flex-development/remark-preset": "1.0.0",
    "@flex-development/tutils": "6.0.0-alpha.25",
    "@flex-development/unist-util-inspect": "1.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@tsconfig/strictest": "2.0.8",
    "@types/concat-stream": "2.0.3",
    "@types/debug": "4.1.13",
    "@types/is-ci": "3.0.4",
    "@types/node-notifier": "8.0.5",
    "@types/rollup": "0.54.0",
    "@types/unist": "3.0.3",
    "@vates/toggle-scripts": "1.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "concat-stream": "2.0.0",
    "convert-hrtime": "5.0.0",
    "cross-env": "10.1.0",
    "cspell": "10.0.1",
    "delete-empty": "3.0.0",
    "dprint": "0.54.0",
    "editorconfig": "3.0.2",
    "eslint": "10.6.0",
    "growl": "1.10.5",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "micromark": "4.0.2",
    "node-notifier": "10.0.1",
    "pkg-size": "2.4.0",
    "remark": "15.0.1",
    "remark-cli": "12.0.1",
    "rollup": "4.62.2",
    "rollup-plugin-cleanup": "3.2.1",
    "rollup-plugin-dts": "6.4.1",
    "sh-syntax": "0.5.8",
    "to-vfile": "8.0.0",
    "trash-cli": "7.2.0",
    "ts-dedent": "2.3.0",
    "tsx": "4.22.5",
    "typescript": "6.0.3",
    "unified": "11.0.5",
    "vfile": "6.0.3",
    "vitest": "4.1.9"
  },
  "packageManager": "yarn@4.17.0",
  "sideEffects": false
}
